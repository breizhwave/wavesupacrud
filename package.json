{
  "name": "supacrud",
  "version": "0.1.0",
  "description": "Open-source admin/CRUD interface for Supabase — pure JavaScript static files, hostable anywhere.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "serve .",
    "css:build": "tailwindcss -i styles/input.css -o styles/main.css --minify",
    "css:watch": "tailwindcss -i styles/input.css -o styles/main.css --watch",
    "vendor": "esbuild @supabase/supabase-js --bundle --format=esm --platform=browser --target=es2022 --outfile=vendor/supabase-js.js",
    "test": "vitest run"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "esbuild": "^0.21.5",
    "serve": "^14.2.3",
    "tailwindcss": "^3.4.4",
    "vitest": "^1.6.0"
  }
}
